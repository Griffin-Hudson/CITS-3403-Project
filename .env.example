# Copy this file to .env and fill in real values before deploying.
# Never commit .env to version control.

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# In dev, set FLASK_DEBUG=true and this can be omitted (an ephemeral key is auto-generated).
SECRET_KEY=

# SQLAlchemy connection string (defaults to SQLite for local dev)
DATABASE_URL=sqlite:///tunefeed.db

# Set to "true" to enable the Werkzeug debugger (dev only — never enable in production)
FLASK_DEBUG=false

# Port the development server binds to
PORT=5002

# ── Spotify OAuth (optional — enables the "Connect with Spotify" feature) ──
# Register your app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:5002/spotify/callback to Redirect URIs in the Spotify dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5002/spotify/callback
